{
	"name": "bbcode-to-react-19",
	"version": "1.0.0",
	"description": "A utility for turning raw BBCode into React elements for React 19",
	"main": "lib/index.js",
	"types": "index.d.ts",
	"scripts": {
		"start": "npm run build",
		"build": "cross-env NODE_ENV=production webpack --progress",
		"prebuild": "babel src --out-dir lib --ignore src/__tests__/",
		"prepare": "npm run build",
		"create-release": "sh ./scripts/release",
		"publish-release": "sh ./scripts/publish",
		"lint": "eslint src --ext .js,.jsx",
		"test": "jest",
		"test:watch": "jest --watch"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/devanist/bbcode-to-react-19.git"
	},
	"files": [
		"LICENSE",
		"README.md",
		"CHANGELOG.md",
		"lib",
		"dist",
		"tonic-example.js",
		"index.d.ts"
	],
	"keywords": [
		"bbcode",
		"react",
		"bbcode parser"
	],
	"contributors": [
		"Junmin Liu (https://github.com/jimliu)",
		"Cédric Verlinden (https://github.com/CedricVerlinden)",
		"Przemysław Lewandowski (https://github.com/devanist)"
	],
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/devanist/bbcode-to-react-19/issues"
	},
	"tonicExampleFilename": "tonic-example.js",
	"homepage": "https://github.com/devanist/bbcode-to-react-19#readme",
	"peerDependencies": {
		"react": "^0.14.0 || ^15.0.0 || ^16.0.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@babel/cli": "^7.28.6",
		"@babel/core": "^7.29.0",
		"@babel/preset-env": "^7.29.0",
		"@babel/preset-react": "^7.28.5",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/jest": "^30.0.0",
		"babel-jest": "^30.2.0",
		"babel-loader": "^10.0.0",
		"clean-webpack-plugin": "^4.0.0",
		"copy-webpack-plugin": "^14.0.0",
		"cross-env": "^10.1.0",
		"eslint": "^7.32.0",
		"eslint-config-airbnb": "^19.0.4",
		"eslint-plugin-import": "^2.6.0",
		"eslint-plugin-react": "^7.1.0",
		"eslint-plugin-standard": "^2.0.0",
		"jest": "^30.2.0",
		"jest-environment-jsdom": "^30.2.0",
		"json-loader": "^0.5.7",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-test-renderer": "^19.2.5",
		"ts-jest": "^29.4.6",
		"webpack": "^5.105.1",
		"webpack-cli": "^7.0.2"
	}
}
